openapi: 3.0.3
info:
  title: UserMint API
  version: 0.1.0
paths:
  /healthz:
    get:
      summary: Liveness
      responses: { '200': { description: OK }}
  /v1/ingest/identify:
    post:
      summary: Resolve ISRC/UPC → draft
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                idType: { type: string, enum: [ISRC, UPC] }
                id: { type: string }
      responses: { '200': { description: OK }}
  /v1/mintables:
    post:
      summary: Create a mintable asset
      responses: { '200': { description: OK }}
  /v1/playback/token:
    post:
      summary: Return signed HLS URL if entitled
      responses: { '200': { description: OK }}
  /v1/hls/key:
    get:
      summary: AES-128 HLS key endpoint (entitlement-gated)
      responses: { '200': { description: OK }}

name: CI API
on:
  push:
    branches: [ main ]
    paths: [ 'api/**' ]
jobs:
  build:
    runs-on: ubuntu-latest
    permissions: { contents: read, id-token: write }
    steps:
      - uses: actions/checkout@v4
      - uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_BUILD_SA }}
      - uses: google-github-actions/setup-gcloud@v2
      - name: Login to Artifact Registry
        run: gcloud auth configure-docker ${{ secrets.GCP_REGION }}-docker.pkg.dev
      - name: Build & Push
        run: |
          IMAGE="${{ secrets.GCP_REGION }}-docker.pkg.dev/${{ secrets.GCP_PROJECT }}/usermint/api:${{ github.sha }}"
          echo "$IMAGE" > api-image.txt
          docker build -t "$IMAGE" ./api
          docker push "$IMAGE"
      - uses: actions/upload-artifact@v4
        with: { name: api-image, path: api-image.txt }

name: CI Worker
on:
  push:
    branches: [ main ]
    paths: [ 'worker/**' ]
jobs:
  build:
    runs-on: ubuntu-latest
    permissions: { contents: read, id-token: write }
    steps:
      - uses: actions/checkout@v4
      - uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_BUILD_SA }}
      - uses: google-github-actions/setup-gcloud@v2
      - name: Login to Artifact Registry
        run: gcloud auth configure-docker ${{ secrets.GCP_REGION }}-docker.pkg.dev
      - name: Build & Push
        run: |
          IMAGE="${{ secrets.GCP_REGION }}-docker.pkg.dev/${{ secrets.GCP_PROJECT }}/usermint/worker:${{ github.sha }}"
          echo "$IMAGE" > worker-image.txt
          docker build -t "$IMAGE" ./worker
          docker push "$IMAGE"
      - uses: actions/upload-artifact@v4
        with: { name: worker-image, path: worker-image.txt }

name: Terraform (dev)
on:
  workflow_dispatch: {}
  push:
    branches: [ main ]
    paths: [ 'infra/**', '.github/workflows/tf-plan-apply.yml' ]
jobs:
  tf:
    runs-on: ubuntu-latest
    permissions: { contents: read, id-token: write }
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        with: { name: api-image, path: . }
      - id: img
        run: echo "image=$(cat api-image.txt || echo latest)" >> $GITHUB_OUTPUT
      - uses: hashicorp/setup-terraform@v3
      - uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_TERRAFORM_SA }}
      - name: Init
        working-directory: infra/environments/dev
        run: terraform init
      - name: Plan
        working-directory: infra/environments/dev
        run: terraform plan -var="api_image=${{ steps.img.outputs.image }}" -var="project_id=${{ secrets.GCP_PROJECT }}" -var="media_bucket_name=media-usermint-dev-${{ github.run_id }}" -var="cdn_signing_key=${{ secrets.CDN_SIGNING_KEY_DEV }}"
      - name: Apply
        working-directory: infra/environments/dev
        run: terraform apply -auto-approve -var="api_image=${{ steps.img.outputs.image }}" -var="project_id=${{ secrets.GCP_PROJECT }}" -var="media_bucket_name=media-usermint-dev-${{ github.run_id }}" -var="cdn_signing_key=${{ secrets.CDN_SIGNING_KEY_DEV }}"

name: Deploy (Dev)

on:
  push:
    branches: [ main ]
    paths:
      - "api/**"
      - "infra/**"
      - ".github/workflows/deploy.yml"
  workflow_dispatch: {}

# Prevent overlapping applies
concurrency:
  group: deploy-dev
  cancel-in-progress: true

jobs:
  build_api:
    name: Build & Push API
    runs-on: ubuntu-latest
    permissions:
      contents: read
      id-token: write  # required for WIF
    env:
      REGION: ${{ secrets.GCP_REGION }}
      PROJECT_ID: ${{ secrets.GCP_PROJECT }}
      REPO: "usermint"                # Artifact Registry repo name
      IMAGE_NAME: "api"
    steps:
      - uses: actions/checkout@v4

      - name: Google Auth (WIF)
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_BUILD_SA }}

      - name: Setup gcloud
        uses: google-github-actions/setup-gcloud@v2

      - name: Configure Docker for Artifact Registry
        run: gcloud auth configure-docker $REGION-docker.pkg.dev --quiet

      - name: Build & Push image
        working-directory: api
        run: |
          IMAGE_URI="$REGION-docker.pkg.dev/$PROJECT_ID/$REPO/$IMAGE_NAME:${GITHUB_SHA}"
          echo "IMAGE_URI=$IMAGE_URI" >> $GITHUB_ENV
          docker build -t "$IMAGE_URI" .
          docker push "$IMAGE_URI"

      - name: Publish image uri artifact
        run: |
          echo "${{ env.IMAGE_URI }}" > image.txt
        shell: bash
      - uses: actions/upload-artifact@v4
        with:
          name: api-image-uri
          path: image.txt

  terraform_dev:
    name: Terraform Apply (Dev)
    runs-on: ubuntu-latest
    needs: build_api
    permissions:
      contents: read
      id-token: write  # required for WIF
    steps:
      - uses: actions/checkout@v4

      - uses: actions/download-artifact@v4
        with:
          name: api-image-uri
          path: .

      - id: read_image
        run: |
          IMG=$(cat image.txt)
          echo "image=$IMG" >> $GITHUB_OUTPUT

      - name: Google Auth (WIF)
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WIF_PROVIDER }}
          service_account: ${{ secrets.GCP_TERRAFORM_SA }}

      - name: Setup gcloud
        uses: google-github-actions/setup-gcloud@v2

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: 1.7.5

      - name: Terraform Init
        working-directory: infra/environments/dev
        run: terraform init

      # Plan is optional; keep for visibility in PRs and logs
      - name: Terraform Plan
        working-directory: infra/environments/dev
        env:
          TF_VAR_project_id: ${{ secrets.GCP_PROJECT }}
          TF_VAR_region: ${{ secrets.GCP_REGION }}
          TF_VAR_zone: us-central1-a
          TF_VAR_media_bucket_name: ${{ vars.MEDIA_BUCKET_DEV }}
          TF_VAR_api_image: ${{ steps.read_image.outputs.image }}
        run: terraform plan -no-color

      - name: Terraform Apply (auto-approve)
        working-directory: infra/environments/dev
        env:
          TF_VAR_project_id: ${{ secrets.GCP_PROJECT }}
          TF_VAR_region: ${{ secrets.GCP_REGION }}
          TF_VAR_zone: us-central1-a
          TF_VAR_media_bucket_name: ${{ vars.MEDIA_BUCKET_DEV }}
          TF_VAR_api_image: ${{ steps.read_image.outputs.image }}
        run: terraform apply -auto-approve
