terraform {
  required_providers { google = { source = "hashicorp/google", version = "~> 5.0" } }
}
provider "google" { project = var.project_id region = var.region zone = var.zone }
resource "google_service_account" "api_sa" { account_id = "usermint-api-dev" display_name = "UserMint API Dev SA" }
resource "google_project_iam_member" "api_token_creator" { project = var.project_id role = "roles/iam.serviceAccountTokenCreator" member = "serviceAccount:${google_service_account.api_sa.email}" }
resource "usermint-media-dev-1 "media" {
  name = var.media_bucket_name = "usermint-media-dev-1"
  location = var.region
  uniform_bucket_level_access = true
  force_destroy = true
  autoclass { enabled = true }
  versioning { enabled = true }
}
resource "google_compute_firewall" "allow_http_https" {
  name = "usermint-allow-http-https" network = "default"
  allow { protocol = "tcp" ports = ["80","443","8080"] }
  direction = "INGRESS" source_ranges = ["0.0.0.0/0"]
  target_service_accounts = [google_service_account.api_sa.email]
}
resource "google_compute_instance" "api_vm" {
  name = "usermint-api-dev" machine_type = "e2-standard-2"
  boot_disk { initialize_params { image = "debian-cloud/debian-12" size = 20 type = "pd-balanced" } }
  network_interface { network = "default" access_config {} }
  service_account { email = google_service_account.api_sa.email scopes = ["https://www.googleapis.com/auth/cloud-platform"] }
  metadata = {
    API_IMAGE       = var.api_image
    MEDIA_BUCKET    = google_storage_bucket.media.name
    CDN_HOST        = var.cdn_host
    CDN_SIGNING_KEY = var.cdn_signing_key
  }
  metadata_startup_script = file("${path.module}/startup.sh")
}
output "api_public_ip" { value = google_compute_instance.api_vm.network_interface[0].access_config[0].nat_ip }
output "media_bucket"  { value = google_storage_bucket.media.name }

output "api_public_ip" { value = google_compute_instance.api_vm.network_interface[0].access_config[0].nat_ip }
