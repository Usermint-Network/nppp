name: Build and Push UserMint API

on:
  push:
    branches: ["main"]
  workflow_dispatch:

env:
  REGION: us-central1
  REPO: usermint
  IMAGE: api

jobs:
  build-and-push:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ secrets.GCP_SA_KEY }}

      - name: Set up gcloud SDK
        uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: usermint-network

      - name: Authenticate Docker to Artifact Registry
        run: gcloud auth configure-docker $REGION-docker.pkg.dev --quiet

      - name: Build Docker image
        run: |
          TAG=$(date +%s)
          echo "TAG=$TAG" >> $GITHUB_ENV
          docker build \
            -f api/Dockerfile \
            -t $REGION-docker.pkg.dev/usermint-network/$REPO/$IMAGE:$TAG \
            ./api

      - name: Push Docker image
        run: |
          docker push $REGION-docker.pkg.dev/usermint-network/$REPO/$IMAGE:$TAG

      - name: Save image tag artifact
        run: echo $TAG > image-tag.txt















