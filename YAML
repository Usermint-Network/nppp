name: Build and Push UserMint API

on:
  push:
    branches: ["main"]
  workflow_dispatch:

env:
  REGION: us-central1
  REPO: usermint
  IMAGE: api

jobs:
  build-and-push:
    runs-on: ubuntu-latest

    permissions:
      id-token: write         # needed for OIDC / Workload Identity
      contents: read          # so the workflow can read the repo

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      # 🔐 Authenticate to Google Cloud via Workload Identity Federation
      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: "projects/192046537667/locations/global/workloadIdentityPools/github-pool/providers/github-provider"
          service_account: "usermint-api-dev@usermint-network.iam.gserviceaccount.com"

      # Set up gcloud SDK (no credentials_json here!)
      - name: Set up gcloud SDK
        uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: usermint-network

      # Configure Docker auth for Artifact Registry
      - name: Authenticate Docker to Artifact Registry
        run: gcloud auth configure-docker $REGION-docker.pkg.dev --quiet

      # Build Docker image
      - name: Build Docker image
        run: |
          TAG=$(date +%s)
          echo "TAG=$TAG" >> $GITHUB_ENV
          docker build \
            -f api/Dockerfile \
            -t $REGION-docker.pkg.dev/usermint-network/$REPO/$IMAGE:$TAG \
            ./api

      # Push Docker image
      - name: Push Docker image
        run: |
          docker push $REGION-docker.pkg.dev/usermint-network/$REPO/$IMAGE:$TAG

      # Optional: print the image tag
      - name: Save image tag artifact
        run: echo $TAG > image-tag.txt
