import time, hmac, hashlib, base64

def sign_url(base: str, path: str, key: str, ttl: int = 300) -> str:
    exp = int(time.time()) + ttl
    msg = f"{path}{exp}".encode()
    sig = base64.urlsafe_b64encode(hmac.new(key.encode(), msg, hashlib.sha256).digest()).decode().strip("=")
    return f"{base}{path}?exp={exp}&sig={sig}"

from typing import List
import hashlib

def _h(x: bytes) -> bytes: return hashlib.sha256(x).digest()

def merkle_root(addresses: List[str]) -> str:
    if not addresses: return ""
    layer = [ _h(bytes.fromhex(a[2:])) for a in [a.lower() for a in addresses] ]
    while len(layer) > 1:
        nxt = []
        for i in range(0, len(layer), 2):
            a = layer[i]
            b = layer[i+1] if i+1 < len(layer) else a
            nxt.append(_h(a + b))
        layer = nxt
    return layer[0].hex()

