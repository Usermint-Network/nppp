from fastapi import APIRouter, HTTPException
from .models import PlaybackReq
from .deps import get_env
from .utils.crypto import sign_url

router = APIRouter()

@router.post("/v1/playback/token")
async def playback_token(req: PlaybackReq):
    env = get_env()
    # TODO: entitlement check (wallet + (albumId|trackId))
    if not (req.albumId or req.trackId):
        raise HTTPException(400, "albumId or trackId required")
    ref = req.albumId or req.trackId
    path = f"/p/{ref}/master.m3u8"
    url = sign_url(env["CDN_HOST"], path, env["CDN_SIGNING_KEY"], ttl=300)
    return {"manifestUrl": url, "expiresIn": 300}

